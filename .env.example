# Copier ce fichier vers .env.local et renseigner les vraies valeurs.
# .env.local n'est jamais commité (voir .gitignore).

# Resend (envoi d'email de notification pour le formulaire de contact)
# https://resend.com -> API Keys
RESEND_API_KEY=
# Adresse expéditrice. Nécessite un domaine vérifié dans Resend pour un
# usage en production ; "onboarding@resend.dev" fonctionne sans
# vérification pour tester.
RESEND_FROM_EMAIL="HEXA <onboarding@resend.dev>"

# Supabase (archivage des messages de contact + articles de blog en base de données)
# https://supabase.com -> Project Settings > API
# Exécuter d'abord supabase/schema.sql dans l'éditeur SQL du projet.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth (connexion à /admin/login)
# Même projet Supabase que ci-dessus. Clé "anon" (publique), pas service_role.
# Créer le compte admin dans Authentication > Users du dashboard Supabase
# (un seul compte, pas d'inscription publique).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
